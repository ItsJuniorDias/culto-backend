{
  "name": "culto-checkout-api",
  "version": "1.0.0",
  "private": true,
  "description": "Backend do fluxo de checkout da CULTO — Fastify + TypeScript, com gateway de pagamento plugável (mock hoje, PradaPay amanhã).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "clean": "rm -rf dist",
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "culto-checkout-api": ".",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
